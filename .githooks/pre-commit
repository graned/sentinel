#!/usr/bin/env bash
# Pre-commit hook: run formatters for Rust and TypeScript in parallel.
#   - Rust  : cargo fmt --all        (when any .rs file is staged)
#   - TS/JS : oxfmt (via npx)        (when any .ts/.tsx/.js/.jsx file is staged)

set -euo pipefail

RUST_FILES=$(git diff --cached --name-only | grep -E '\.rs$' || true)
TS_FILES=$(git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx)$' || true)

# Exit early if nothing needs formatting
if [[ -z "$RUST_FILES" && -z "$TS_FILES" ]]; then
    exit 0
fi

# ── Output helpers ───────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

info()    { echo -e "${BOLD}[pre-commit]${RESET} $*"; }
success() { echo -e "${GREEN}[pre-commit]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[pre-commit]${RESET} $*"; }
error()   { echo -e "${RED}[pre-commit]${RESET} $*" >&2; }

# ── Formatter functions ──────────────────────────────────────────────────────
run_cargo_fmt() {
    info "Rust files detected — running cargo fmt --all..."
    if cargo fmt --all; then
        # Re-stage any files that were reformatted
        git diff --name-only | grep -E '\.rs$' | xargs -r git add
        success "cargo fmt complete."
    else
        error "cargo fmt failed."
        return 1
    fi
}

run_oxfmt() {
    info "TypeScript/JavaScript files detected — running oxfmt..."
    local ui_dir="apps/sentinel-ui"
    if [[ ! -d "$ui_dir" ]]; then
        warn "Could not find $ui_dir — skipping oxfmt."
        return 0
    fi
    # oxfmt operates on the src directory; run from the ui package root
    if (cd "$ui_dir" && npx oxfmt src); then
        # Re-stage any files that were reformatted
        git diff --name-only | grep -E '\.(ts|tsx|js|jsx)$' | xargs -r git add
        success "oxfmt complete."
    else
        error "oxfmt failed."
        return 1
    fi
}

# ── Run in parallel ──────────────────────────────────────────────────────────
pids=()

if [[ -n "$RUST_FILES" ]]; then
    run_cargo_fmt &
    pids+=($!)
fi

if [[ -n "$TS_FILES" ]]; then
    run_oxfmt &
    pids+=($!)
fi

# Wait for all background jobs and collect exit codes
failed=0
for pid in "${pids[@]}"; do
    if ! wait "$pid"; then
        failed=1
    fi
done

if [[ "$failed" -ne 0 ]]; then
    error "One or more formatters failed. Please fix the errors above and retry."
    exit 1
fi

info "All formatters passed."
