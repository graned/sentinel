# ─────────────────────────────────────────────────────────────────────────────
# Sentinel Auth — environment variables
#
# Copy this file to .env and fill in every value before starting the stack.
# .env is gitignored; never commit real secrets.
#
# Usage:
#   cp .env.example .env
#   docker compose --profile db up -d          # bundled postgres
#   docker compose up -d                       # external postgres (set DATABASE_URL)
#
# For named environments:
#   docker compose --env-file .env.prod up -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string used by sentinel-core and the migrate service.
# If using the bundled postgres (--profile db) this should match the
# POSTGRES_* variables below:  postgresql://<USER>:<PASSWORD>@postgres:5432/<DB>
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/sentinel_auth

# Only required when using the bundled postgres service (--profile db).
POSTGRES_DB=sentinel_auth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme


# ── Security keys (REQUIRED — generate with: openssl rand -hex 32) ────────────

# 32-byte hex key used to encrypt/decrypt PASETO session tokens.
# Changing this invalidates all existing sessions.
HEX_KEY=

# 32-byte hex key used to encrypt stored secrets at rest:
# OIDC signing keys, MFA TOTP secrets, SMTP provider credentials.
# Changing this invalidates all stored encrypted data.
CONFIG_ENCRYPTION_KEY=


# ── URLs ─────────────────────────────────────────────────────────────────────

# Public base URL where sentinel-core is reachable (used in OIDC tokens as
# the issuer claim and in OIDC discovery document URLs).
# Example: https://api.auth.example.com
OIDC_ISSUER_URL=http://localhost:9000

# Base URL for links embedded in emails (verification, password reset).
# Should point to wherever sentinel-ui is hosted.
# Example: https://auth.example.com
FRONTEND_URL=http://localhost:3000

# Comma-separated list of origins allowed to make cross-origin requests to
# sentinel-core.  Typically the URL(s) where sentinel-ui is served.
# If unset, all cross-origin requests are denied.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public URL of sentinel-core as seen from the end-user's browser.
# Baked into the sentinel-ui JS bundle at build time by Vite.
# Must match OIDC_ISSUER_URL when both are on the same host.
VITE_API_URL=http://localhost:9000


# ── Port mapping (optional — defaults shown) ──────────────────────────────────

# Host port that maps to sentinel-core's internal port 8000.
# API_PORT=9000

# Host port that maps to sentinel-ui's nginx on port 80.
# UI_PORT=3000


# ── Logging (optional) ────────────────────────────────────────────────────────

# Rust tracing filter for sentinel-core.  Valid values: error, warn, info,
# debug, trace.  Use a directive like "sentinel_core=debug,info" for
# fine-grained control.
# RUST_LOG=info


# ── Image tagging (optional — used when pulling pre-built images) ─────────────

# Tag applied to the built images.  Useful when pushing to a registry.
# IMAGE_TAG=latest
