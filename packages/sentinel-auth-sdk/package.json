{
  "name": "@sentinel/auth-sdk",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "description": "TypeScript SDK for Sentinel Auth — login, session management, and error handling",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "mocha",
    "test:unit": "mocha tests/session.test.ts tests/user-client.test.ts",
    "test:integration": "mocha tests/login.test.ts tests/register.test.ts tests/user.test.ts",
    "lint": "biome lint ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "check": "biome check --write ./src ./tests"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/mocha": "^10.0.0",
    "@types/pg": "^8.11.0",
    "chai": "^5.1.0",
    "mocha": "^10.7.0",
    "pg": "^8.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "sentinel",
    "auth",
    "authentication",
    "sdk"
  ]
}
