{
  "name": "@sentinel/auth-react",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sentinel/auth-sdk": "*",
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6",
    "zustand": ">=4"
  },
  "dependencies": {
    "uqr": "^0.1.2"
  },
  "devDependencies": {
    "@sentinel/auth-sdk": "file:../sentinel-auth-sdk",
    "@tanstack/react-query": "^5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7",
    "typescript": "~5.9",
    "vite": "^7",
    "vite-plugin-dts": "^4",
    "zustand": "^5"
  }
}
